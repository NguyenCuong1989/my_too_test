rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Lead capture: Cho phép bất kỳ ai gửi thông tin nhưng không ai được đọc public
    match /leads/{lead} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Các phần khác chặn toàn bộ mặc định
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
