{
    "typescript.tsdk": "DAIOF-Framework/vscode-merged/node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}/axcontrol"
    ],
    "python.analysis.autoImportCompletions": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.diagnosticMode": "workspace",
    "python.terminal.activateEnvInSelectedTerminal": true,
    "css.lint.unknownAtRules": "ignore",
    "github-actions.workflows.pinned.workflows": [
        ".github/workflows/no-drift-gate.yml"
    ],
    "workbench.colorTheme": "Default Dark+",
    "python.defaultInterpreterPath": "/opt/homebrew/bin/python3.13",
    "php.validate.executablePath": "",
    "php.suggest.basic": false,
    "python.testing.pytestArgs": [
        "."
    ],
    "python.testing.unittestEnabled": true,
    "python.testing.pytestEnabled": false,
    "markdown.validate.enabled": true,
    "files.associations": {
        "*.py": "python"
    },
    "[python]": {
        "yaml.validate": false,
        "github.copilot.nextEditSuggestions.enabled": true
    },
    "yaml.validate": false,
    "yaml.schemas": {
        "http://json.schemastore.org/no-op": "**/*.py"
    },
    "yaml.customTags": [],
    "[markdown]": {
        "github.copilot.nextEditSuggestions.enabled": false
    },
    "[typescript]": {
        "github.copilot.nextEditSuggestions.enabled": true
    },
    "[javascript]": {
        "github.copilot.nextEditSuggestions.enabled": true
    },
    "geminicodeassist.inlineSuggestions.enableAuto": true,
    "geminicodeassist.inlineSuggestions.nextEditPredictions": false,
    "geminicodeassist.agentYoloMode": false,
    "github.copilot.chat.searchSubagent.enabled": false,
    "claudeCode.initialPermissionMode": "default",
    "claudeCode.autosave": true,
    "claudeCode.usePythonEnvironment": false
}
